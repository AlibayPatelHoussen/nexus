# ─── SERVER ───────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── DATABASE ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus
DB_USER=nexus_user
DB_PASSWORD=your_strong_password_here

# ─── AUTH ─────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── MEDIA PATHS ──────────────────────────────────────
MEDIA_ROOT=/media
FILMS_PATH=/media/films
SERIES_PATH=/media/series
ANIMES_PATH=/media/animes
MANGA_PATH=/media/scans
YOUTUBE_PATH=/media/youtube
SCRIPTS_PATH=/media/scripts

# ─── EXTERNAL APIs ────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# AniList — no key needed (GraphQL public API)
ANILIST_API_URL=https://graphql.anilist.co

# MangaDex — no key needed
MANGADEX_API_URL=https://api.mangadex.org

# ─── RATE LIMITING ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── LOGGING ──────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/nexus.log
